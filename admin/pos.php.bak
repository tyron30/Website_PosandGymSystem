            justify-content: space-between;
            min-width: 300px;
            opacity: 0;
            transform: translateX(100%);
            transition: all 0.3s ease;
        }
        .toast.show {
            opacity: 1;
            transform: translateX(0);
        }
        .toast.success {
            border-left: 4px solid #28a745;
        }
        .toast.warning {
            border-left: 4px solid #ffc107;
